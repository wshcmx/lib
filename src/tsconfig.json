{
  "compilerOptions": {
    "target": "esnext",
    "module": "Preserve",
    "noLib": true,
    "rootDir": ".",
    "outDir": "../dist",
    "declaration": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "noImplicitThis": true,
    "typeRoots": [
      "../node_modules/@wshcmx/types/lib",
      "../node_modules/@wshcmx/types/lib/xml"
    ]
  },
  "include": [
    "*.ts"
  ]
}
