{
  "compilerOptions": {
    "target": "es5",
    "module": "Preserve",
    "noLib": true,
    "rootDir": ".",
    "outDir": "../dist",
    "declaration": true,
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "allowUnusedLabels": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "noImplicitThis": true,
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "*.ts",
    "*.d.ts",
    "../node_modules/@wshcmx/types/lib/**/*.d.ts"
  ]
}
