{
  "compilerOptions": {
    "target": "esnext",
    "module": "Preserve",
    "noLib": true,
    "rootDir": ".",
    "outDir": "../dist",
    "declaration": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "noImplicitThis": true
  },
  "include": [
    "*.ts",
    "*.d.ts",
    "../node_modules/@wshcmx/types/lib/**/*.d.ts"
  ]
}
